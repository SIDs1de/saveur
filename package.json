{
  "name": "saveur",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "pnpm scss:types && concurrently \"next dev\" \"pnpm scss:types:watch\"",
    "build": "pnpm scss:types && next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "scss:types": "typed-scss-modules src --outputFolder __generated__ --exportType default",
    "scss:types:watch": "typed-scss-modules src --outputFolder __generated__ --exportType default --watch --ignoreInitial",
    "test": "vitest run",
    "test:watch": "vitest",
    "types": "tsc --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm scss:types && pnpm types && pnpm test",
    "check:push": "pnpm check",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/nextjs-registry": "^1.3.0",
    "antd": "^6.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "mobx": "^6.15.4",
    "mobx-react-lite": "^4.1.1",
    "next": "16.2.6",
    "normalize.css": "^8.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.77.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
